# ── Secrets & local config ──────────────────────────────────────────────────
.env
.env.local
.env.*.local

# Google OAuth client secret (never commit — use env/settings UI instead)
client_secret*.json

# ── Go build artifacts ───────────────────────────────────────────────────────
/bin/
/server
*.test
*.out
coverage.txt

# ── Frontend ─────────────────────────────────────────────────────────────────
/web/node_modules/
/web/dist/
/web/*.tsbuildinfo

# Auto-generated by @tanstack/router-plugin — rebuilt on `pnpm dev`
/web/src/routeTree.gen.ts

# Embedded SPA artifact (built into binary; never check in built files)
/internal/web/dist/*
!/internal/web/dist/.gitkeep

# ── Real trade data — NEVER commit ───────────────────────────────────────────
/transactions-csv/

# ── Runtime data ─────────────────────────────────────────────────────────────
/data/
/tmp/

# ── Internal planning / tool-specific docs ───────────────────────────────────
/PRD.md
/ANTIGRAVITY.md

# ── Tool workspaces ──────────────────────────────────────────────────────────
/temp_venv/
/.antigravitycli/

# Claude Code local settings (personal, not shared)
.claude/settings.local.json

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
