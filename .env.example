# Copy to .env and fill in values. Never commit .env.

# --- Database ---
DB_PASSWORD=change-me
DATABASE_URL=postgres://wealthfolio:change-me@db:5432/wealthfolio?sslmode=disable

# --- Required ---
JWT_SECRET=replace-with-64-char-hex   # openssl rand -hex 64

# --- App ---
APP_ENV=production
TZ=Asia/Kolkata
PORT=8000

# --- Uploads ---
UPLOAD_DIR=/data/uploads
UPLOAD_MAX_MB=10
PROFILE_PIC_MAX_MB=5

# --- Scheduler (hours in IST, 24h) ---
SNAPSHOT_HOUR=23
MARKET_MOOD_HOUR=19
GMAIL_WATCHER_HOUR=7
GMAIL_LOOKBACK_DAYS=7

# --- Optional integrations ---
# ZERODHA_PDF_PASSWORD=YOUR_PAN
