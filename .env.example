# Copy to .env and fill in values. Never commit .env.

# --- Required ---
DATABASE_URL=postgres://wealthfolio:change-me@db:5432/wealthfolio?sslmode=disable
JWT_SECRET=replace-with-openssl-rand-hex-64   # openssl rand -hex 64

# --- App ---
APP_ENV=production
TZ=Asia/Kolkata

# --- Uploads ---
UPLOAD_DIR=/data/uploads

# --- Scheduler (hours in IST, 24h) ---
# SNAPSHOT_HOUR=23      # default: 23
# MARKET_MOOD_HOUR=19   # default: 19
# GMAIL_WATCHER_HOUR=7  # default: 7

# --- Gmail import (optional) ---
# GMAIL_LOOKBACK_DAYS=7             # default: 7 — days back to scan
# ZERODHA_PDF_PASSWORD=YOUR_PAN     # PDF password for Zerodha contract notes
